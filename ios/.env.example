# TorchCI iOS App - Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# GitHub OAuth (for authentication flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Developer Team
TEAM_ID=wouterdevriendt

# App Store Connect API (for Fastlane uploads)
# Generate at: https://appstoreconnect.apple.com/access/integrations/api
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_KEY_PATH=

# Fastlane Match (code signing sync)
MATCH_PASSWORD=

# Fastlane Apple-specific password (for pilot/deliver)
# Generate at: https://appleid.apple.com/account/manage -> App-Specific Passwords
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=

# TorchCI backend base URL
TORCHCI_BASE_URL=https://hud.pytorch.org
